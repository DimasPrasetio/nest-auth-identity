{
  "name": "@elcodelabs/nest-auth-identity",
  "version": "0.1.0",
  "description": "Reusable NestJS auth and identity package with configurable storage adapters.",
  "private": true,
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DimasPrasetio/nest-auth-identity.git"
  },
  "bugs": {
    "url": "https://github.com/DimasPrasetio/nest-auth-identity/issues"
  },
  "homepage": "https://github.com/DimasPrasetio/nest-auth-identity#readme",
  "type": "commonjs",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "PRD.md",
    "Plan.md"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rimraf dist coverage *.tsbuildinfo",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "prepare": "npm run build",
    "test": "vitest run",
    "test:package": "node test/package-consumer-smoke.mjs",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "pack:check": "npm pack --dry-run"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "@nestjs/core": "^10.0.0 || ^11.0.0",
    "reflect-metadata": "^0.1.13 || ^0.2.0",
    "rxjs": "^7.8.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.27.0",
    "@nestjs/common": "^11.1.1",
    "@nestjs/core": "^11.1.1",
    "@nestjs/platform-express": "^11.1.21",
    "@nestjs/testing": "^11.1.21",
    "@swc/core": "^1.15.33",
    "@types/node": "^22.15.18",
    "eslint": "^9.27.0",
    "reflect-metadata": "^0.2.2",
    "rimraf": "^6.0.1",
    "rxjs": "^7.8.2",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.1",
    "vitest": "^3.1.3"
  }
}
